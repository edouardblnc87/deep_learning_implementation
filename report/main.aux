\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Diagnostics: Inside the Trained Network}{18}{subsection.4.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.3.1}Weight and Activation Distributions}{19}{subsubsection.4.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces \emph  {Good} configuration (ReLU + He normal). Rows: weight distributions, pre-activations, post-activations. Columns: layers~1, 2, output. Blue~$=$ before training; red~$=$ after. All three layers show substantial weight spreading and healthy activation ranges.}}{19}{figure.caption.31}\protected@file@percent }
\newlabel{fig:fnn_good}{{12}{19}{\emph {Good} configuration (ReLU + He normal). Rows: weight distributions, pre-activations, post-activations. Columns: layers~1, 2, output. Blue~$=$ before training; red~$=$ after. All three layers show substantial weight spreading and healthy activation ranges}{figure.caption.31}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces \emph  {Bad} configuration (Sigmoid + standard init). Same layout. Weights barely move during training; layer~2 post-activations collapse to the narrow interval $[0.9,\,1.0]$ --- the saturation zone --- transmitting essentially no information to the output.}}{20}{figure.caption.32}\protected@file@percent }
\newlabel{fig:fnn_bad}{{13}{20}{\emph {Bad} configuration (Sigmoid + standard init). Same layout. Weights barely move during training; layer~2 post-activations collapse to the narrow interval $[0.9,\,1.0]$ --- the saturation zone --- transmitting essentially no information to the output}{figure.caption.32}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.3.2}Gradient Flow}{21}{subsubsection.4.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Gradient $\ell _2$-norms per layer over 150~epochs. Left (ReLU + He): all layers maintain comparable norms throughout. Right (Sigmoid + standard): early layers receive gradients 2--3$\times $ smaller than the output layer.}}{21}{figure.caption.33}\protected@file@percent }
\newlabel{fig:fnn_grad}{{14}{21}{Gradient $\ell _2$-norms per layer over 150~epochs. Left (ReLU + He): all layers maintain comparable norms throughout. Right (Sigmoid + standard): early layers receive gradients 2--3$\times $ smaller than the output layer}{figure.caption.33}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.3.3}Weight Evolution During Training}{21}{subsubsection.4.3.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Weight distribution snapshots at epochs 0, 10, 30, 100, 200 (ReLU + He normal, best config). All three layers exhibit progressive spreading from a tight initialisation to broad, learned distributions.}}{21}{figure.caption.34}\protected@file@percent }
\newlabel{fig:fnn_evolution}{{15}{21}{Weight distribution snapshots at epochs 0, 10, 30, 100, 200 (ReLU + He normal, best config). All three layers exhibit progressive spreading from a tight initialisation to broad, learned distributions}{figure.caption.34}{}}

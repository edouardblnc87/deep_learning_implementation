\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Test MAE as a function of momentum coefficient~$\mu $. Performance improves steadily to $\mu =0.95$; at $\mu =0.99$ the model diverges.}}{16}{figure.caption.25}\protected@file@percent }
\newlabel{fig:fnn_momentum}{{9}{16}{Test MAE as a function of momentum coefficient~$\mu $. Performance improves steadily to $\mu =0.95$; at $\mu =0.99$ the model diverges}{figure.caption.25}{}}

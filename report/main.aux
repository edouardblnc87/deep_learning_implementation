\@writefile{lof}{\contentsline {figure}{\numberline {22}{\ignorespaces Weight distributions before training. $W_{ih}$ (input$\to $hidden), $W_{hh}$ (hidden$\to $hidden, the memory matrix), and the linear head. All initialised in tight distributions around zero.}}{30}{figure.caption.53}\protected@file@percent }
\newlabel{fig:rnn_weights_before}{{22}{30}{Weight distributions before training. $W_{ih}$ (input$\to $hidden), $W_{hh}$ (hidden$\to $hidden, the memory matrix), and the linear head. All initialised in tight distributions around zero}{figure.caption.53}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {23}{\ignorespaces Weight distributions after training. $W_{hh}$ shows the most pronounced reshaping: the distribution widens and develops structure, confirming that the recurrent pathway is actively used by the trained model.}}{30}{figure.caption.54}\protected@file@percent }
\newlabel{fig:rnn_weights_after}{{23}{30}{Weight distributions after training. $W_{hh}$ shows the most pronounced reshaping: the distribution widens and develops structure, confirming that the recurrent pathway is actively used by the trained model}{figure.caption.54}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.4.2}Hidden State Activity}{31}{subsubsection.5.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {24}{\ignorespaces Average hidden state activation at each sequence position before training. Activity rises from the zero initialisation then plateaus, reflecting the warmup from $\mathbf  {h}_0 = \mathbf  {0}$.}}{31}{figure.caption.55}\protected@file@percent }
\newlabel{fig:rnn_hidden_before}{{24}{31}{Average hidden state activation at each sequence position before training. Activity rises from the zero initialisation then plateaus, reflecting the warmup from $\mathbf {h}_0 = \mathbf {0}$}{figure.caption.55}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {25}{\ignorespaces Average hidden state activation after training. The shape (rise then plateau) is unchanged, but the saturation level has increased from $\approx 0.125$ to $\approx 0.325$ --- a $2.5\times $ amplification --- indicating that training taught the network to store more information in each hidden state.}}{31}{figure.caption.56}\protected@file@percent }
\newlabel{fig:rnn_hidden_after}{{25}{31}{Average hidden state activation after training. The shape (rise then plateau) is unchanged, but the saturation level has increased from $\approx 0.125$ to $\approx 0.325$ --- a $2.5\times $ amplification --- indicating that training taught the network to store more information in each hidden state}{figure.caption.56}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.4.3}Input Sensitivity by Lag}{32}{subsubsection.5.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {26}{\ignorespaces Input sensitivity before training: how much does perturbing $\mathbf  {x}_t$ move the final prediction? Sensitivity collapses at lags 2--3; the model is effectively ignoring all but the most recent inputs.}}{32}{figure.caption.57}\protected@file@percent }
\newlabel{fig:rnn_sensitivity_before}{{26}{32}{Input sensitivity before training: how much does perturbing $\mathbf {x}_t$ move the final prediction? Sensitivity collapses at lags 2--3; the model is effectively ignoring all but the most recent inputs}{figure.caption.57}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {27}{\ignorespaces Input sensitivity after training. Sensitivity is now distributed across the full 20-lag window, demonstrating that training has taught the recurrent pathway to route historical context to the final prediction.}}{32}{figure.caption.58}\protected@file@percent }
\newlabel{fig:rnn_sensitivity_after}{{27}{32}{Input sensitivity after training. Sensitivity is now distributed across the full 20-lag window, demonstrating that training has taught the recurrent pathway to route historical context to the final prediction}{figure.caption.58}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.5}Failure Analysis}{33}{subsection.5.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.5.1}Residuals Over Time}{33}{subsubsection.5.5.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {28}{\ignorespaces Residuals over time by regime. White line: true absolute return. Coloured area: absolute prediction error $|y - \hat  {y}|$. The error envelope tracks the true volatility signal: small and stable in the calm regime, elevated in clustering, and spiking sharply during the COVID crash.}}{33}{figure.caption.59}\protected@file@percent }
\newlabel{fig:rnn_residuals}{{28}{33}{Residuals over time by regime. White line: true absolute return. Coloured area: absolute prediction error $|y - \hat {y}|$. The error envelope tracks the true volatility signal: small and stable in the calm regime, elevated in clustering, and spiking sharply during the COVID crash}{figure.caption.59}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.5.2}Error vs Magnitude}{34}{subsubsection.5.5.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {29}{\ignorespaces True volatility vs.\ prediction error, coloured by regime. The positive slope confirms mean-reversion bias across all regimes. Histograms (right) show the direction of the bias per regime: the spikes histogram is shifted furthest left (systematic under-prediction); the calm histogram is nearly centred.}}{34}{figure.caption.60}\protected@file@percent }
\newlabel{fig:rnn_error_magnitude}{{29}{34}{True volatility vs.\ prediction error, coloured by regime. The positive slope confirms mean-reversion bias across all regimes. Histograms (right) show the direction of the bias per regime: the spikes histogram is shifted furthest left (systematic under-prediction); the calm histogram is nearly centred}{figure.caption.60}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.5.3}Worst Predictions Per Regime}{34}{subsubsection.5.5.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {30}{\ignorespaces Worst predictions --- calm regime. Failures are simply the largest true volatility values within the regime; there is no identifiable input pattern. The model's error is magnitude-driven, not structure-driven.}}{35}{figure.caption.61}\protected@file@percent }
\newlabel{fig:rnn_worst_calm}{{30}{35}{Worst predictions --- calm regime. Failures are simply the largest true volatility values within the regime; there is no identifiable input pattern. The model's error is magnitude-driven, not structure-driven}{figure.caption.61}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {31}{\ignorespaces Worst predictions --- clustering regime. Same pattern as calm: failures coincide with the largest true values; no systematic lookback pattern is visible.}}{35}{figure.caption.62}\protected@file@percent }
\newlabel{fig:rnn_worst_clustering}{{31}{35}{Worst predictions --- clustering regime. Same pattern as calm: failures coincide with the largest true values; no systematic lookback pattern is visible}{figure.caption.62}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {32}{\ignorespaces Worst predictions --- spikes regime. Both worst cases show extreme COVID-level volatility ($\approx 0.046$) already in the input window. The model's prediction is far too small: it never learned to output values of this magnitude because they were essentially absent from the training set.}}{36}{figure.caption.63}\protected@file@percent }
\newlabel{fig:rnn_worst_spikes}{{32}{36}{Worst predictions --- spikes regime. Both worst cases show extreme COVID-level volatility ($\approx 0.046$) already in the input window. The model's prediction is far too small: it never learned to output values of this magnitude because they were essentially absent from the training set}{figure.caption.63}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.6}Vanishing Gradient Diagnosis}{36}{subsection.5.6}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.6.1}$W_{hh}$ Spectral Radius}{36}{subsubsection.5.6.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {33}{\ignorespaces Singular value spectrum of $W_{hh}$ after training. Spectral radius $\rho = 1.4$ (exploding regime overall), but roughly 57 of the 64 directions lie below~1. Training has deliberately pushed 5--7 directions above~1 to maintain gradient flow through the tanh saturation; gradient clipping prevents these from causing instability.}}{36}{figure.caption.64}\protected@file@percent }
\newlabel{fig:rnn_spectrum}{{33}{36}{Singular value spectrum of $W_{hh}$ after training. Spectral radius $\rho = 1.4$ (exploding regime overall), but roughly 57 of the 64 directions lie below~1. Training has deliberately pushed 5--7 directions above~1 to maintain gradient flow through the tanh saturation; gradient clipping prevents these from causing instability}{figure.caption.64}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.6.2}Output Sensitivity per Time Step}{37}{subsubsection.5.6.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {34}{\ignorespaces Output sensitivity to the hidden state at each time step: $\partial \hat  {y}/\partial \mathbf  {h}_t$ as a function of lag. Sensitivity decays by 50\,\% at step~1 and is essentially zero by step~2 --- the prediction is nearly insensitive to any hidden state older than one step.}}{37}{figure.caption.65}\protected@file@percent }
\newlabel{fig:rnn_grad_norms}{{34}{37}{Output sensitivity to the hidden state at each time step: $\partial \hat {y}/\partial \mathbf {h}_t$ as a function of lag. Sensitivity decays by 50\,\% at step~1 and is essentially zero by step~2 --- the prediction is nearly insensitive to any hidden state older than one step}{figure.caption.65}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.6.3}Effective Memory}{37}{subsubsection.5.6.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {35}{\ignorespaces Effective memory: correlation between the final hidden state $\mathbf  {h}_T$ and each input $\mathbf  {x}_t$ at different lags. Despite the near-zero gradient norms beyond lag~2, the correlation decays gradually across the full 20-lag window and remains meaningful at lags 15--20.}}{37}{figure.caption.66}\protected@file@percent }
\newlabel{fig:rnn_effective_memory}{{35}{37}{Effective memory: correlation between the final hidden state $\mathbf {h}_T$ and each input $\mathbf {x}_t$ at different lags. Despite the near-zero gradient norms beyond lag~2, the correlation decays gradually across the full 20-lag window and remains meaningful at lags 15--20}{figure.caption.66}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.6.4}Effective Memory by Regime}{38}{subsubsection.5.6.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {36}{\ignorespaces Effective memory split by regime. Calm: smooth exponential decay from $\approx 0.55$ to $0.05$--$0.12$. Clustering: similar shape but sharper drop, concentrated on the most recent days. Spikes: highest initial correlation ($\approx 0.60$) with a non-monotonic profile and secondary peaks at lags~7--11 and~12--17, reflecting the autocorrelation structure of the COVID crash itself.}}{38}{figure.caption.67}\protected@file@percent }
\newlabel{fig:rnn_memory_regime}{{36}{38}{Effective memory split by regime. Calm: smooth exponential decay from $\approx 0.55$ to $0.05$--$0.12$. Clustering: similar shape but sharper drop, concentrated on the most recent days. Spikes: highest initial correlation ($\approx 0.60$) with a non-monotonic profile and secondary peaks at lags~7--11 and~12--17, reflecting the autocorrelation structure of the COVID crash itself}{figure.caption.67}{}}

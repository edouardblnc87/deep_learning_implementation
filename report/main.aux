\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Validation loss (MSE) over 300 epochs for four activations. ReLU (red, MAE~$=0.607$) reaches the best test MAE; Sigmoid (orange) is still declining at epoch~300.}}{13}{figure.caption.19}\protected@file@percent }
\newlabel{fig:fnn_activations}{{6}{13}{Validation loss (MSE) over 300 epochs for four activations. ReLU (red, MAE~$=0.607$) reaches the best test MAE; Sigmoid (orange) is still declining at epoch~300}{figure.caption.19}{}}

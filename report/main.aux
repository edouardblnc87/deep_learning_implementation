\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces \emph  {Good} configuration (ReLU + He normal). Rows: weight distributions, pre-activations, post-activations. Columns: layers~1, 2, output. Blue~$=$ before training; red~$=$ after. All three layers show substantial weight spreading and healthy activation ranges.}}{20}{figure.caption.31}\protected@file@percent }
\newlabel{fig:fnn_good}{{12}{20}{\emph {Good} configuration (ReLU + He normal). Rows: weight distributions, pre-activations, post-activations. Columns: layers~1, 2, output. Blue~$=$ before training; red~$=$ after. All three layers show substantial weight spreading and healthy activation ranges}{figure.caption.31}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces \emph  {Bad} configuration (Sigmoid + standard init). Same layout. Weights barely move during training; layer~2 post-activations collapse to the narrow interval $[0.9,\,1.0]$ --- the saturation zone --- transmitting essentially no information to the output.}}{21}{figure.caption.32}\protected@file@percent }
\newlabel{fig:fnn_bad}{{13}{21}{\emph {Bad} configuration (Sigmoid + standard init). Same layout. Weights barely move during training; layer~2 post-activations collapse to the narrow interval $[0.9,\,1.0]$ --- the saturation zone --- transmitting essentially no information to the output}{figure.caption.32}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.3.2}Gradient Flow}{22}{subsubsection.4.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Gradient $\ell _2$-norms per layer over 150~epochs. Left (ReLU + He): all layers maintain comparable norms throughout. Right (Sigmoid + standard): early layers receive gradients 2--3$\times $ smaller than the output layer.}}{22}{figure.caption.33}\protected@file@percent }
\newlabel{fig:fnn_grad}{{14}{22}{Gradient $\ell _2$-norms per layer over 150~epochs. Left (ReLU + He): all layers maintain comparable norms throughout. Right (Sigmoid + standard): early layers receive gradients 2--3$\times $ smaller than the output layer}{figure.caption.33}{}}
